# Copy to ".env" for local dev. On Vercel: Project → Settings → Environment Variables (Production + Preview).

# --- Required ---
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-project.vercel.app"

# NextAuth on Vercel / behind proxies (recommended)
AUTH_TRUST_HOST="true"

# --- Public ---
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
NEXT_PUBLIC_WHATSAPP="919876543210"

# --- Optional ---
# RESEND_API_KEY="re_..."
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
